" Improved Vim Configuration
" Based on current minimal setup with essential improvements

" === EXISTING: Syntax highlighting ===
syntax on

" === EXISTING: Line numbers ===
set nu

" === EXISTING: 4 space tabs ===
filetype plugin indent on
set expandtab
set tabstop=4
set shiftwidth=4

" === EXISTING: Memory settings ===
" (These seem unusually high - consider if still needed)
set maxmem=6753250
set maxmemtot=6753250
set maxmempattern=6691516

" === NEW: Search improvements ===
" Case insensitive search unless uppercase letters are used
set ignorecase
set smartcase
" Highlight search results as you type
set hlsearch
set incsearch
" Clear search highlighting with <leader><space>
nnoremap <leader><space> :nohlsearch<CR>

" === NEW: Keep cursor centered ===
" Always keep 8 lines visible above/below cursor
set scrolloff=8
set sidescrolloff=8

" === NEW: Better line wrapping ===
" Wrap long lines at word boundaries
set wrap
set linebreak

" === NEW: Show matching brackets ===
set showmatch

" === NEW: Better backspace behavior ===
" Allow backspacing over everything in insert mode
set backspace=indent,eol,start

" === NEW: Persistent undo ===
" Keep undo history across vim sessions
set undofile
set undodir=~/.vim/undo
" Create undo directory if it doesn't exist
if !isdirectory($HOME."/.vim/undo")
    call mkdir($HOME."/.vim/undo", "p", 0700)
endif

" === NEW: Better split behavior ===
" Open splits below and to the right (more natural)
set splitbelow
set splitright

" === NEW: Show trailing whitespace ===
" Makes tabs and trailing spaces visible
set list
set listchars=tab:→\ ,trail:·,nbsp:␣

" === NEW: Cursor line highlight ===
" Highlight the line the cursor is on
set cursorline

" === NEW: Better command-line completion ===
set wildmenu
set wildmode=longest:full,full

" === NEW: Show partial commands ===
set showcmd

" === NEW: Mouse support ===
" Enable mouse in all modes (useful for resizing splits)
set mouse=a

" === NEW: Update time ===
" Faster update time (better for plugins, git gutter, etc.)
set updatetime=250

" === NEW: Auto-reload files changed outside vim ===
set autoread

" === NEW: Better navigation between splits ===
" Use Ctrl+hjkl to navigate between splits
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" === NEW: Quick save ===
" Use ,w to save (comma is easier than reaching for colon)
nnoremap <leader>w :w<CR>

" === NEW: Move lines up/down ===
" Alt+j/k moves lines down/up
nnoremap <A-j> :m .+1<CR>==
nnoremap <A-k> :m .-2<CR>==
inoremap <A-j> <Esc>:m .+1<CR>==gi
inoremap <A-k> <Esc>:m .-2<CR>==gi
vnoremap <A-j> :m '>+1<CR>gv=gv
vnoremap <A-k> :m '<-2<CR>gv=gv

" === NEW: Keep visual selection when indenting ===
vnoremap < <gv
vnoremap > >gv

" === NEW: Better Y behavior ===
" Make Y behave like D and C (yank to end of line)
nnoremap Y y$

" === NEW: Center screen after search ===
nnoremap n nzzzv
nnoremap N Nzzzv

" === NEW: Join lines without moving cursor ===
nnoremap J mzJ`z

" === NEW: Undo break points ===
" Create undo break points while typing (makes undo more granular)
inoremap , ,<c-g>u
inoremap . .<c-g>u
inoremap ! !<c-g>u
inoremap ? ?<c-g>u
