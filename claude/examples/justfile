# Example justfile for project automation
# Run `just` to see available commands
#
# Recipes describe outcomes, not implementation.
# Adapt commands to your project's tools and conventions.

# Default recipe shows help
default:
    @just --list

# Linting and formatting
lint:  # Catch-all for quality checks. May check typing, compilation, formatting, etc.
    @echo "Run linting commands appropriate for your project"
    # Python: uv run ruff check . && uv run mypy .
    # Rust: cargo clippy -- -D warnings && cargo fmt --check

format:  # Auto-format code to match style guide
    @echo "Run formatting commands"
    # Python: uv run ruff format .
    # Rust: cargo fmt

# Testing
test-unit:  # Run unit tests only
    @echo "Run unit tests"
    # Python: uv run pytest tests/unit
    # Rust: cargo test --lib

test-integration:  # Run integration tests only (may require services)
    @echo "Run integration tests"
    # Python: uv run pytest tests/integration
    # Rust: cargo test --test integration

test-coverage:  # Run unit tests with coverage report
    @echo "Run tests with coverage"
    # Python: uv run pytest --cov --cov-report=html
    # Rust: cargo tarpaulin --out Html

test: test-unit test-integration  # Run all tests

# Build and check
build:  # Build the project (compile, package, etc.)
    @echo "Build project"
    # Python: uv build
    # Rust: cargo build --release

check: lint test  # Run all quality checks (what CI runs)
    @echo "All checks passed!"

# Development environment
install:  # Install dependencies
    @echo "Install dependencies"
    # Python: uv sync
    # Rust: cargo build

dev:  # Start development environment
    @echo "Start development environment"
    # Docker: docker compose up -d
    # Django: uv run python manage.py runserver
    # Rust: cargo watch -x run

# Docker operations
docker-up:  # Start all services
    docker compose up -d

docker-down:  # Stop all services
    docker compose down

docker-logs service="":  # View logs for service (or all if none specified)
    docker compose logs -f {{service}}

docker-shell service:  # Open shell in running service
    docker compose exec {{service}} /bin/bash

# Database operations
db-migrate:  # Apply database migrations
    @echo "Apply migrations"
    # Python: uv run alembic upgrade head
    # Rust: sqlx migrate run
    # Django: uv run python manage.py migrate

db-rollback:  # Rollback last migration
    @echo "Rollback migration"
    # Python: uv run alembic downgrade -1
    # Rust: sqlx migrate revert

db-shell:  # Open database shell
    docker compose exec postgres psql -U myuser -d mydb

# Cleanup
clean:  # Remove build artifacts and caches
    @echo "Clean build artifacts"
    # Python: find . -type d -name "__pycache__" -exec rm -rf {} +
    # Rust: cargo clean
    # All: rm -rf .venv/ htmlcov/ .coverage
